generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContextType {
  CITY
  UNIVERSITY
  MALL
}

enum Country {
  COLOMBIA
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  lastName  String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  spots     Spot[]
  favorites Favorite[]

  @@map("users")
}

model Category {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  spots       Spot[]

  @@map("categories")
}

model City {
  id      Int     @id @default(autoincrement())
  name    String
  country Country

  contexts Context[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, country])
  @@map("cities")
}

model Context {
  id        Int         @id @default(autoincrement())
  name      String
  type      ContextType
  cityId    Int
  city      City        @relation(fields: [cityId], references: [id], onDelete: Restrict)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  spots Spot[]

  @@index([cityId])
  @@map("contexts")
}

model Spot {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  latitude    Float
  longitude   Float
  address     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  contextId Int
  context   Context @relation(fields: [contextId], references: [id], onDelete: Restrict)

  images    Image[]
  favorites Favorite[]

  @@index([userId])
  @@index([categoryId])
  @@index([contextId])
  @@index([latitude, longitude])
  @@map("spots")
}

model Image {
  id        Int      @id @default(autoincrement())
  url       String
  order     Int?
  spotId    Int
  spot      Spot     @relation(fields: [spotId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([spotId])
  @@map("images")
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  spotId    Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  spot Spot @relation(fields: [spotId], references: [id], onDelete: Cascade)

  @@unique([userId, spotId])
  @@index([userId])
  @@index([spotId])
  @@map("favorites")
}
